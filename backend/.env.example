# Environment
ENVIRONMENT=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Security
SECRET_KEY=dev-secret-key-change-in-production

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Resend (Email)
RESEND_API_KEY=re_...
EMAIL_FROM=NMB Media <noreply@nmbmedia.com>

# Frontend URL (used for email CTA links and CORS)
FRONTEND_URL=https://staffing.nmbmedia.com

# CORS (comma-separated origins)
CORS_ORIGINS=https://staffing.nmbmedia.com,https://frontend-production-b5f1.up.railway.app

# Twilio (SMS)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# W-9 / payout encryption (rotate carefully — encrypted columns become unreadable)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
W9_ENCRYPTION_KEY=

# PayPal Payouts API + Log In with PayPal (https://developer.paypal.com)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_MODE=sandbox
# Optional override; defaults to {FRONTEND_URL}/api/profile/paypal/callback
PAYPAL_LOGIN_REDIRECT_URI=

# QuickBooks Online (https://developer.intuit.com)
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REDIRECT_URI=
QBO_ENVIRONMENT=sandbox

# Payer business info (used on W-9 and 1099-NEC PDFs)
PAYER_BUSINESS_NAME=NMB Media
PAYER_ADDRESS_LINE1=
PAYER_CITY=
PAYER_STATE=
PAYER_ZIP=
PAYER_EIN=
